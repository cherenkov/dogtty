#!/bin/bash
# dogtty — show an AI-generated dog in the corner of your Ghostty terminal.
#
#   dogtty                     generate a new dog now
#   dogtty "corgi, pixel art"  generate with a custom prompt
#   dogtty install             install & register the launchd job
#                              (interactive on a TTY; silent defaults otherwise)
#   dogtty config              change the dog, the look and the interval
#   dogtty uninstall           remove everything
#
# Images are generated by Pollinations.ai (free, no API key), saved to
# ~/.local/share/dogtty/dogtty.png, and Ghostty reloads via SIGUSR2
# (officially supported since Ghostty 1.2 — never send any other signal;
# unhandled signals kill the process).
#
# Note: anonymous Pollinations.ai usage is rate-limited (HTTP 429 on rapid
# requests); generation retries up to 3 times with a 15-second wait.
set -euo pipefail

# Messages follow the user's locale: Japanese when LANG is ja*, English otherwise
JA=0; [[ "${LANG:-}" == ja* ]] && JA=1
msg() { if [[ "${JA}" == 1 ]]; then echo "$2"; else echo "$1"; fi }

BIN_TARGET="$HOME/.local/bin/dogtty"
LABEL="local.dogtty"
PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"
IMG_DIR="$HOME/.local/share/dogtty"
LOG_FILE="$HOME/Library/Logs/dogtty.log"
SUBJECT_FILE="$HOME/.config/dogtty/subject"
STYLE_FILE="$HOME/.config/dogtty/style"
DEFAULT_SUBJECT="cute shiba inu"
DEFAULT_STYLE="mixed"
DEFAULT_INTERVAL=180

valid_interval() { [[ "$1" =~ ^[0-9]+$ ]] && (( $1 >= 60 )); }

# Prompt for the interval; Enter keeps the current value (shown in brackets)
ask_interval() {
  local cur="$1" prompt val
  if [[ "${JA}" == 1 ]]; then
    prompt="犬が替わる間隔を秒で入力してください（最小60） [Enterで現在のまま: ${cur}]: "
  else
    prompt="How often should the dog change, in seconds? (min 60) [Enter to keep: ${cur}]: "
  fi
  while :; do
    read -r -p "$prompt" val
    val="${val:-$cur}"
    if valid_interval "$val"; then echo "$val"; return; fi
    msg "Please enter a number of 60 or more." "60以上の数字を入力してください。" >&2
  done
}

# Interactive picker for the dog; Enter keeps the current value.
# Menus go to stderr because the choice is returned on stdout.
choose_subject() {
  local current="$1" sel custom
  while :; do
    if [[ "${JA}" == 1 ]]; then
      {
        echo "どの犬を表示しますか？（現在: ${current}）"
        echo "  1) 柴犬"
        echo "  2) シーズー"
        echo "  3) コーギー"
        echo "  4) トイプードル"
        echo "  5) ゴールデンレトリバー"
        echo "  6) 自由入力"
      } >&2
      read -r -p "選択 [Enterで現在のまま]: " sel
    else
      {
        echo "Which dog should appear? (current: ${current})"
        echo "  1) Shiba inu"
        echo "  2) Shih tzu"
        echo "  3) Corgi"
        echo "  4) Toy poodle"
        echo "  5) Golden retriever"
        echo "  6) Custom prompt"
      } >&2
      read -r -p "Choice [Enter to keep]: " sel
    fi
    case "$sel" in
      "") echo "$current"; return ;;
      1) echo "cute shiba inu"; return ;;
      2) echo "cute shih tzu"; return ;;
      3) echo "cute corgi"; return ;;
      4) echo "cute toy poodle"; return ;;
      5) echo "cute golden retriever"; return ;;
      6)
        if [[ "${JA}" == 1 ]]; then
          read -r -p "プロンプトを英語で入力（例: cute black cat）: " custom
        else
          read -r -p "Enter a custom prompt (e.g. cute black cat): " custom
        fi
        if [[ -n "$custom" ]]; then echo "$custom"; return; fi
        ;;
    esac
    msg "Please choose 1-6." "1〜6で選んでください。" >&2
  done
}

# save_pref <file> <value>
save_pref() {
  mkdir -p "$(dirname "$1")"
  printf '%s\n' "$2" > "$1"
}

# Human-readable label for a stored style value (for menu display)
style_label() {
  case "$1" in
    mixed) msg "Mixed" "おまかせ" ;;
    illustration) msg "Illustration" "イラスト風" ;;
    photo) msg "Photo" "写真風" ;;
    *) echo "$1" ;;
  esac
}

# Interactive picker for the image tone; Enter keeps the current value.
# Returns a pool keyword ("mixed" / "illustration" / "photo") or a free-form style.
choose_style() {
  local current="$1" sel custom
  while :; do
    if [[ "${JA}" == 1 ]]; then
      {
        echo "画像のテイストは？（現在: $(style_label "$current")）"
        echo "  1) おまかせ（イラスト風・写真風からランダム）"
        echo "  2) イラスト風（水彩・パステル・フラット・色鉛筆）"
        echo "  3) 写真風（DSLR・フィルム）"
        echo "  4) 自由入力"
      } >&2
      read -r -p "選択 [Enterで現在のまま]: " sel
    else
      {
        echo "Which look do you prefer? (current: $(style_label "$current"))"
        echo "  1) Mixed (random illustration & photo)"
        echo "  2) Illustration (watercolor, pastel, flat, colored pencil)"
        echo "  3) Photo (DSLR, film)"
        echo "  4) Custom style prompt"
      } >&2
      read -r -p "Choice [Enter to keep]: " sel
    fi
    case "$sel" in
      "") echo "$current"; return ;;
      1) echo "mixed"; return ;;
      2) echo "illustration"; return ;;
      3) echo "photo"; return ;;
      4)
        if [[ "${JA}" == 1 ]]; then
          read -r -p "テイストを英語で入力（例: pixel art）: " custom
        else
          read -r -p "Enter a custom style (e.g. pixel art): " custom
        fi
        if [[ -n "$custom" ]]; then echo "$custom"; return; fi
        ;;
    esac
    msg "Please choose 1-4." "1〜4で選んでください。" >&2
  done
}

write_plist() {
  cat > "$PLIST" <<PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>${LABEL}</string>
	<key>ProgramArguments</key>
	<array>
		<string>${BIN_TARGET}</string>
	</array>
	<key>StartInterval</key>
	<integer>$1</integer>
	<key>RunAtLoad</key>
	<true/>
	<key>StandardOutPath</key>
	<string>${LOG_FILE}</string>
	<key>StandardErrorPath</key>
	<string>${LOG_FILE}</string>
</dict>
</plist>
PLIST_EOF
}

register_launchd() {
  launchctl bootout "gui/$(id -u)/${LABEL}" 2>/dev/null || true
  # launchd occasionally fails with EIO right after a bootout and needs a few
  # seconds to settle; retry with increasing waits
  local i
  for i in 1 2 3 4 5; do
    launchctl bootstrap "gui/$(id -u)" "$PLIST" 2>/dev/null && return 0
    if [[ "$i" == 5 ]]; then
      msg "Failed to register with launchd. Run manually: launchctl bootstrap gui/$(id -u) $PLIST" \
          "launchdへの登録に失敗しました。手動で実行してください: launchctl bootstrap gui/$(id -u) $PLIST" >&2
      return 1
    fi
    sleep "$i"
  done
}

# Ask dog → look → interval, prefilled with the current settings (or defaults
# on first run). Saves the picks and echoes the chosen interval.
run_wizard() {
  local cur_subject="$DEFAULT_SUBJECT" cur_style="$DEFAULT_STYLE" cur_interval="$DEFAULT_INTERVAL"
  [[ -f "$SUBJECT_FILE" ]] && cur_subject=$(<"$SUBJECT_FILE")
  [[ -f "$STYLE_FILE" ]] && cur_style=$(<"$STYLE_FILE")
  if [[ -f "$PLIST" ]]; then
    cur_interval=$(sed -n 's|.*<integer>\([0-9]*\)</integer>.*|\1|p' "$PLIST")
    cur_interval="${cur_interval:-$DEFAULT_INTERVAL}"
  fi
  save_pref "$SUBJECT_FILE" "$(choose_subject "$cur_subject")"
  save_pref "$STYLE_FILE" "$(choose_style "$cur_style")"
  ask_interval "$cur_interval"
}

# ---- subcommands ("install", "uninstall" and "config" are reserved words
# ---- and can't be used as generation prompts)

if [[ "${1:-}" == "install" ]]; then
  # Interactive on a TTY; silent defaults otherwise (CI, pipes)
  INTERVAL="$DEFAULT_INTERVAL"
  if [[ -t 0 ]]; then
    INTERVAL=$(run_wizard)
  fi

  # Install this script itself as a real copy — a symlink into e.g. ~/Documents
  # would break under launchd because of macOS TCC folder protection
  mkdir -p "$(dirname "$BIN_TARGET")"
  if ! cmp -s "$0" "$BIN_TARGET"; then
    cp "$0" "$BIN_TARGET"
    chmod +x "$BIN_TARGET"
  fi

  write_plist "$INTERVAL"
  register_launchd

  msg "dogtty installed (a new dog every ${INTERVAL} seconds)" \
      "dogtty をインストールしました（${INTERVAL}秒ごとに犬が替わります）"
  # Heads-up if ~/.local/bin isn't in PATH (only affects manual runs; launchd is fine)
  case ":${PATH}:" in
    *":${HOME}/.local/bin:"*) ;;
    *) msg "Note: ~/.local/bin is not in your PATH. Add it if you want to run 'dogtty' manually." \
           "注意: ~/.local/bin にPATHが通っていません。手動で 'dogtty' を実行するにはPATHに追加してください。" ;;
  esac
  echo ""
  msg "Now add the following to your Ghostty config (~/.config/ghostty/config):" \
      "あとは Ghostty 設定（~/.config/ghostty/config）に以下を追記してください:"
  echo ""
  echo "  background-image = ~/.local/share/dogtty/dogtty.png"
  echo "  background-image-position = bottom-right"
  echo "  background-image-fit = none"
  echo "  background-image-opacity = 0.3"
  exit 0
fi

if [[ "${1:-}" == "uninstall" ]]; then
  launchctl bootout "gui/$(id -u)/${LABEL}" 2>/dev/null || true
  rm -f "$PLIST" "$LOG_FILE"
  rm -rf "$IMG_DIR" "$HOME/.config/dogtty"
  # Unlinking the running script is safe: bash keeps reading from the open fd
  rm -f "$BIN_TARGET"
  msg "dogtty uninstalled" "dogtty をアンインストールしました"
  msg "Please remove the 4 background-image lines from your Ghostty config (~/.config/ghostty/config) manually" \
      "Ghostty 設定（~/.config/ghostty/config）の background-image 4行は手動で削除してください"
  exit 0
fi

if [[ "${1:-}" == "config" ]]; then
  if [[ ! -f "$PLIST" ]]; then
    msg "dogtty is not installed. Run: dogtty install" \
        "dogtty がインストールされていません。先に dogtty install を実行してください。" >&2
    exit 1
  fi
  if [[ ! -t 0 ]]; then
    msg "dogtty config is interactive; run it in a terminal." \
        "dogtty config は対話専用です。ターミナルで実行してください。" >&2
    exit 1
  fi
  INTERVAL=$(run_wizard)
  write_plist "$INTERVAL"
  register_launchd
  msg "Settings updated (interval: ${INTERVAL}s)" "設定を更新しました（間隔: ${INTERVAL}秒）"
  exit 0
fi

# ---- generation (no subcommand)

# Keep the launchd log from growing forever (truncate above 1MB)
if [[ -f "$LOG_FILE" ]] && (( $(stat -f%z "$LOG_FILE") > 1048576 )); then
  : > "$LOG_FILE"
fi

# Do nothing when Ghostty isn't running (no display target, so don't burn API calls)
GHOSTTY_PID=$(ps aux | grep "Ghostty.app/Contents/MacOS/ghostty" | grep -v grep | awk '{print $2}' | head -1)
if [[ -z "${GHOSTTY_PID}" ]]; then
  msg "Ghostty is not running; skipping" "Ghostty が起動していないためスキップ"
  exit 0
fi

POSES=("sitting" "sleeping curled up" "running happily" "tilting its head" "smiling with tongue out" "lying down relaxed")
ILLUST_STYLES=("watercolor style" "soft pastel illustration" "cute flat illustration" "gentle colored pencil sketch")
PHOTO_STYLES=("photorealistic, dslr photo, natural lighting, shallow depth of field" "candid film photograph, warm tones, soft bokeh")

if [[ $# -gt 0 ]]; then
  PROMPT="$*"
else
  SUBJECT="$DEFAULT_SUBJECT"
  [[ -f "$SUBJECT_FILE" ]] && SUBJECT=$(<"$SUBJECT_FILE")
  STYLE_PREF="$DEFAULT_STYLE"
  [[ -f "$STYLE_FILE" ]] && STYLE_PREF=$(<"$STYLE_FILE")
  case "$STYLE_PREF" in
    mixed)
      ALL_STYLES=("${ILLUST_STYLES[@]}" "${PHOTO_STYLES[@]}")
      STYLE=${ALL_STYLES[RANDOM % ${#ALL_STYLES[@]}]} ;;
    illustration)
      STYLE=${ILLUST_STYLES[RANDOM % ${#ILLUST_STYLES[@]}]} ;;
    photo)
      STYLE=${PHOTO_STYLES[RANDOM % ${#PHOTO_STYLES[@]}]} ;;
    *)
      # free-form style saved via the picker's custom option
      STYLE="$STYLE_PREF" ;;
  esac
  POSE=${POSES[RANDOM % ${#POSES[@]}]}
  PROMPT="${SUBJECT}, ${POSE}, ${STYLE}, simple white background"
fi

ENCODED=$(python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1]))" "$PROMPT")
SEED=$RANDOM

TMP=$(mktemp -t dogtty)
trap 'rm -f "$TMP"' EXIT

msg "Generating: ${PROMPT}" "生成中: ${PROMPT}"
for attempt in 1 2 3; do
  CODE=$(curl -sL --max-time 60 -o "$TMP" -w "%{http_code}" \
    -A "dogtty (https://github.com/cherenkov/dogtty)" \
    "https://image.pollinations.ai/prompt/${ENCODED}?width=512&height=512&nologo=true&seed=${SEED}") || CODE="timeout"
  if [[ "$CODE" == "200" ]]; then
    break
  fi
  if [[ "$attempt" == 3 ]]; then
    msg "Generation failed (HTTP ${CODE}). The service seems busy; try again in a minute." \
        "生成失敗 (HTTP ${CODE})。混雑しているので1分ほど待ってから再実行してください。" >&2
    exit 1
  fi
  msg "Busy (HTTP ${CODE}). Retrying in 15s (${attempt}/3)..." \
      "混雑中 (HTTP ${CODE})。15秒待って再試行します (${attempt}/3)..."
  sleep 15
done

mkdir -p "$IMG_DIR"
sips -s format png -Z 300 "$TMP" --out "$IMG_DIR/dogtty.png" >/dev/null
msg "New dog: ${PROMPT} (seed=${SEED})" "新しい犬: ${PROMPT} (seed=${SEED})"

# Reload Ghostty's config via SIGUSR2 (never send any other signal)
kill -USR2 "${GHOSTTY_PID}" && msg "Ghostty reloaded (pid ${GHOSTTY_PID})" "Ghostty をリロードしました (pid ${GHOSTTY_PID})"
